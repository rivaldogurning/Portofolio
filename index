<style>
  :root{
    --ink:#14171C;
    --ink-soft:#4B5259;
    --paper:#FBFBF8;
    --paper-dim:#F1F2ED;
    --line:#E1E2DB;
    --signal:#2F6F5E;
    --signal-soft:#DCE9E4;
    --forecast:#B8862F;
    --forecast-soft:#F3E8D3;
    --radius:2px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'IBM Plex Sans', sans-serif;
    font-size:16px;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3{
    font-family:'Space Grotesk', sans-serif;
    margin:0;
    letter-spacing:-0.01em;
  }
  .mono{
    font-family:'IBM Plex Mono', monospace;
  }
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--signal);
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:14px;
  }
  .eyebrow::before{
    content:"";
    width:20px;
    height:1px;
    background:var(--signal);
    display:inline-block;
  }
  a{color:inherit;}
  .wrap{
    max-width:1080px;
    margin:0 auto;
    padding:0 32px;
  }
  /* Header */
  header{
    position:sticky;
    top:0;
    z-index:50;
    background:rgba(251,251,248,0.86);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--line);
  }
  .nav{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:18px 32px;
    max-width:1080px;
    margin:0 auto;
  }
  .nav .brand{
    font-family:'Space Grotesk', sans-serif;
    font-weight:600;
    font-size:1.05rem;
  }
  .nav .brand span{color:var(--signal);}
  .nav ul{
    list-style:none;
    display:flex;
    gap:28px;
    margin:0;
    padding:0;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.82rem;
  }
  .nav ul a{
    text-decoration:none;
    color:var(--ink-soft);
    transition:color 0.2s ease;
  }
  .nav ul a:hover, .nav ul a:focus-visible{color:var(--signal);}
  .nav-toggle{display:none;background:none;border:none;cursor:pointer;padding:8px;}
  .nav-toggle span{display:block;width:22px;height:2px;background:var(--ink);margin:5px 0;}

  /* Hero */
  .hero{
    padding:100px 32px 70px;
    max-width:1080px;
    margin:0 auto;
    display:grid;
    grid-template-columns:1.1fr 0.9fr;
    gap:56px;
    align-items:center;
  }
  .hero h1{
    font-size:clamp(2.6rem, 5vw, 4rem);
    font-weight:700;
    line-height:1.05;
    margin-bottom:18px;
  }
  .hero .tagline{
    font-size:1.12rem;
    color:var(--ink-soft);
    max-width:46ch;
    margin-bottom:28px;
  }
  .stat-row{
    display:flex;
    flex-wrap:wrap;
    gap:10px 22px;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.82rem;
    color:var(--ink-soft);
    margin-bottom:34px;
  }
  .stat-row b{color:var(--ink);font-weight:500;}
  .cta-row{display:flex;gap:14px;flex-wrap:wrap;}
  .btn{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.85rem;
    padding:13px 22px;
    border-radius:var(--radius);
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    gap:8px;
    transition:all 0.2s ease;
    border:1px solid var(--ink);
  }
  .btn-solid{background:var(--ink);color:var(--paper);}
  .btn-solid:hover{background:var(--signal);border-color:var(--signal);}
  .btn-ghost{background:transparent;color:var(--ink);}
  .btn-ghost:hover{border-color:var(--signal);color:var(--signal);}

  .hero-visual{
    background:var(--paper-dim);
    border:1px solid var(--line);
    border-radius:6px;
    padding:26px 22px 20px;
  }
  .hero-visual svg{width:100%;height:auto;display:block;}
  .chart-caption{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--ink-soft);
    margin-top:14px;
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:6px;
  }
  .dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;}
  .dot.g{background:var(--signal);}
  .dot.f{background:var(--forecast);}

  #actual-path{
    stroke-dasharray:520;
    stroke-dashoffset:520;
    animation:draw 1.6s ease forwards 0.3s;
  }
  #forecast-path{
    stroke-dasharray:6 6;
    stroke-dashoffset:220;
    opacity:0;
    animation:draw2 1.2s ease forwards 1.7s;
  }
  @keyframes draw{to{stroke-dashoffset:0;}}
  @keyframes draw2{
    0%{stroke-dashoffset:220;opacity:0;}
    10%{opacity:1;}
    100%{stroke-dashoffset:0;opacity:1;}
  }
  #forecast-point{
    opacity:0;
    animation:pop 0.4s ease forwards 2.8s;
  }
  @keyframes pop{from{opacity:0;transform:scale(0.4);}to{opacity:1;transform:scale(1);}}

  @media (prefers-reduced-motion: reduce){
    #actual-path,#forecast-path,#forecast-point{animation:none !important;opacity:1 !important;stroke-dashoffset:0 !important;}
  }

  section{
    padding:78px 0;
    border-top:1px solid var(--line);
  }
  .section-head{
    margin-bottom:40px;
    max-width:60ch;
  }
  .section-head h2{
    font-size:clamp(1.7rem,3vw,2.3rem);
    font-weight:600;
  }

  /* About */
  .about-grid{
    display:grid;
    grid-template-columns:170px 1fr;
    gap:40px;
    align-items:start;
  }
  .avatar{
    width:170px;
    height:170px;
    border-radius:50%;
    object-fit:cover;
    border:1px solid var(--line);
    filter:grayscale(0.15);
  }
  .about-body p{margin:0 0 16px;color:var(--ink-soft);max-width:62ch;}
  .about-body strong{color:var(--ink);font-weight:600;}

  /* Projects */
  .project-featured{
    border:1px solid var(--line);
    border-radius:6px;
    padding:32px;
    margin-bottom:24px;
    background:var(--paper-dim);
  }
  .project-tag{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--signal);
    text-transform:uppercase;
    letter-spacing:0.08em;
    margin-bottom:10px;
    display:block;
  }
  .project-featured h3{font-size:1.5rem;margin-bottom:12px;}
  .project-featured p{color:var(--ink-soft);max-width:70ch;margin:0 0 20px;}
  .stat-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:12px;
    margin-bottom:20px;
  }
  .stat-box{
    border:1px solid var(--line);
    background:var(--paper);
    padding:14px 16px;
    border-radius:4px;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.8rem;
    color:var(--ink-soft);
  }
  .stat-box b{color:var(--ink);display:block;font-size:0.86rem;margin-bottom:4px;font-weight:500;}
  .tags{display:flex;flex-wrap:wrap;gap:8px;}
  .tag{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    padding:5px 10px;
    border:1px solid var(--line);
    border-radius:20px;
    color:var(--ink-soft);
  }
  .project-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:20px;
  }
  .project-card{
    border:1px solid var(--line);
    border-radius:6px;
    padding:24px;
    transition:transform 0.2s ease, border-color 0.2s ease;
  }
  .project-card:hover{transform:translateY(-4px);border-color:var(--signal);}
  .project-card h3{font-size:1.05rem;margin-bottom:10px;}
  .project-card p{color:var(--ink-soft);font-size:0.92rem;margin:0 0 16px;}

  /* Experience timeline */
  .timeline{position:relative;padding-left:28px;}
  .timeline::before{
    content:"";
    position:absolute;
    left:5px;top:6px;bottom:6px;
    width:1px;
    background:var(--line);
  }
  .t-item{position:relative;margin-bottom:36px;}
  .t-item:last-child{margin-bottom:0;}
  .t-item::before{
    content:"";
    position:absolute;
    left:-28px;top:5px;
    width:9px;height:9px;
    border-radius:50%;
    background:var(--signal);
    border:2px solid var(--paper);
    box-shadow:0 0 0 1px var(--signal);
  }
  .t-date{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.78rem;
    color:var(--signal);
    margin-bottom:6px;
    display:block;
  }
  .t-item h3{font-size:1.1rem;margin-bottom:2px;}
  .t-org{color:var(--ink-soft);font-size:0.92rem;margin-bottom:10px;display:block;}
  .t-item ul{margin:0;padding-left:18px;color:var(--ink-soft);}
  .t-item li{margin-bottom:6px;}

  .org-list{
    margin-top:36px;
    padding-top:28px;
    border-top:1px dashed var(--line);
  }
  .org-list .label{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--ink-soft);
    text-transform:uppercase;
    letter-spacing:0.08em;
    margin-bottom:14px;
    display:block;
  }
  .org-row{display:flex;gap:16px;font-size:0.9rem;color:var(--ink-soft);margin-bottom:8px;}
  .org-row .mono{color:var(--ink);white-space:nowrap;}

  /* Education */
  .edu-grid{display:flex;flex-direction:column;gap:22px;}
  .edu-item{
    display:grid;
    grid-template-columns:160px 1fr;
    gap:24px;
    padding-bottom:22px;
    border-bottom:1px solid var(--line);
  }
  .edu-item:last-child{border-bottom:none;}
  .edu-item h3{font-size:1.05rem;margin-bottom:4px;}
  .edu-item p{margin:0;color:var(--ink-soft);font-size:0.92rem;}

  /* Skills */
  .skill-grid{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:28px;
  }
  .skill-group .label{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--signal);
    text-transform:uppercase;
    letter-spacing:0.08em;
    margin-bottom:14px;
    display:block;
  }
  .skill-group ul{list-style:none;margin:0;padding:0;}
  .skill-group li{
    padding:8px 0;
    border-bottom:1px solid var(--line);
    font-size:0.92rem;
  }

  /* Contact */
  .contact-box{
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    flex-wrap:wrap;
    gap:30px;
  }
  .contact-box h2{font-size:clamp(2rem,4vw,2.8rem);max-width:14ch;}
  .contact-list{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.9rem;
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .contact-list a{text-decoration:none;border-bottom:1px solid var(--line);padding-bottom:2px;transition:border-color 0.2s ease, color 0.2s ease;}
  .contact-list a:hover{color:var(--signal);border-color:var(--signal);}

  footer{
    padding:26px 32px;
    border-top:1px solid var(--line);
    font-family:'IBM Plex Mono', monospace;
    font-size:0.75rem;
    color:var(--ink-soft);
    text-align:center;
  }

  .reveal{
    opacity:0;
    transform:translateY(16px);
    transition:opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.in{opacity:1;transform:translateY(0);}

  @media (max-width: 860px){
    .hero{grid-template-columns:1fr;padding-top:120px;}
    .about-grid{grid-template-columns:1fr;}
    .avatar{width:120px;height:120px;}
    .project-grid{grid-template-columns:1fr;}
    .stat-grid{grid-template-columns:1fr;}
    .skill-grid{grid-template-columns:1fr 1fr;}
    .edu-item{grid-template-columns:1fr;gap:6px;}
    .contact-box{flex-direction:column;align-items:flex-start;}
    .nav ul{
      position:fixed;
      top:64px;left:0;right:0;
      background:var(--paper);
      flex-direction:column;
      padding:20px 32px;
      border-bottom:1px solid var(--line);
      display:none;
      gap:16px;
    }
    .nav ul.open{display:flex;}
    .nav-toggle{display:block;}
  }
  @media (max-width: 560px){
    .skill-grid{grid-template-columns:1fr;}
  }
</style>
</head>
